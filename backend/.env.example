# -- LLM (switch provider without code changes) --
# Options: anthropic | kimi | openai
LLM_PROVIDER=openai
# Override default model for the chosen provider (optional)
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_MODEL=moonshot-v1-32k
# LLM_MODEL=gpt-4o-mini
# LLM_MAX_TOKENS=4096

ANTHROPIC_API_KEY=sk-ant-...
MOONSHOT_API_KEY=sk-...
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1   # default (international)
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1   # China platform keys
OPENAI_API_KEY=sk-...
# Optional: generate an executive-summary infographic at the end of cross-reference
# OPENAI_IMAGE_MODEL=gpt-image-2

# -- Bright Data (optional — fact-check agent) --
# BRIGHTDATA_API_TOKEN=
# BRIGHTDATA_SERP_ZONE=serp_api1
# FACT_CHECK_MAX_CLAIMS=6

# -- Video --
VIDEODB_API_KEY=
# VIDEODB_LANGUAGE_CODE=en

# -- App --
DATABASE_URL=sqlite+aiosqlite:///./veluate.db
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:3000

# -- Demo script (app.scripts.run_demo) --
# DEMO_YOUTUBE_URL=https://www.youtube.com/watch?v=...
# FRONTEND_URL=http://localhost:3000
